# Supabase
NUXT_SUPABASE_URL=
NUXT_SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar Service Account (paste full JSON string)
NUXT_GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Calendar ID (legacy: all locations share one calendar)
NUXT_GCAL_CALENDAR_ID=

# Legacy per-location calendar IDs (混合班表/公休/預約)
NUXT_GCAL_CALENDAR_ID_TAIPEI=
NUXT_GCAL_CALENDAR_ID_TAICHUNG=
NUXT_GCAL_CALENDAR_ID_KAOHSIUNG=

# === 拆分日曆架構 ===
# 'true' 啟用：班表/公休 = SCHEDULE 日曆，客戶預約 = BOOKING 日曆
# 'false' 或留空：使用上方 legacy 單一日曆
NUXT_USE_SPLIT_CALENDARS=false

# 新架構：班表 + 公休（手 key 維護）
NUXT_GCAL_CALENDAR_ID_TAIPEI_SCHEDULE=
NUXT_GCAL_CALENDAR_ID_TAICHUNG_SCHEDULE=
NUXT_GCAL_CALENDAR_ID_KAOHSIUNG_SCHEDULE=

# 新架構：客戶預約（程式寫入）
NUXT_GCAL_CALENDAR_ID_TAIPEI_BOOKING=
NUXT_GCAL_CALENDAR_ID_TAICHUNG_BOOKING=
NUXT_GCAL_CALENDAR_ID_KAOHSIUNG_BOOKING=

# LINE Messaging API
NUXT_LINE_CHANNEL_ACCESS_TOKEN=
NUXT_LINE_STAFF_GROUP_ID=
NUXT_LINE_STAFF_GROUP_ID_KAOHSIUNG=
NUXT_LINE_STAFF_GROUP_ID_TAIPEI=
NUXT_LINE_STAFF_GROUP_ID_TAICHUNG=

# PostHog (兩個專案共用同一個 Project API Key)
NUXT_PUBLIC_POSTHOG_KEY=
NUXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NUXT_PUBLIC_SITE_NAME=picosure-booking

# Build preset (set when deploying to Cloudflare Pages)
# NITRO_PRESET=cloudflare-pages
